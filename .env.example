# Copy to .env and fill values. Never commit .env
#   cp .env.example .env

# ---- Browser Use Cloud ----
BROWSER_USE_API_KEY=

# ---- RoxyBrowser local API ----
ROXY_API_TOKEN=

# ---- Cloudflare domain email via QQ IMAP ----
QQ_IMAP_PASSWORD=

# ---- Codex / CPA / SMS (only if you enable Codex) ----
CPA_MANAGEMENT_KEY=
SMS_API_KEY=
L_ADMIN_AUTH_CODE=
